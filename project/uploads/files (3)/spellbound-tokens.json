{
  "name": "Spellbound Design System",
  "version": "2.0",
  "description": "Tokens for Spellbound — a kids' spelling-bee trainer. Default identity is 'Marquee' (a theatrical playbill); ten additional theme skins re-map the same token names.",
  "global": {
    "font": {
      "display": "'Fraunces','Georgia',serif",
      "body": "'Hanken Grotesk','Segoe UI',sans-serif",
      "mono": "'Space Mono',monospace",
      "import": "https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,500;600;700&family=Hanken+Grotesk:wght@400;500;600;700;800&family=Space+Mono:wght@400;700&family=Baloo+2:wght@500;600;700;800&family=Quicksand:wght@500;600;700&family=Orbitron:wght@600;700;800&family=Fredoka:wght@500;600;700&display=swap"
    },
    "radius": {
      "sm": "8px",
      "md": "12px",
      "lg": "14px",
      "xl": "16px",
      "pill": "999px"
    },
    "space": {
      "xs": "4px",
      "sm": "8px",
      "md": "12px",
      "lg": "14px",
      "xl": "18px",
      "2xl": "24px"
    },
    "typeScale": {
      "display-hero": "clamp(34px,9vw,52px)",
      "h2": "22px",
      "h3": "16px",
      "body": "15px",
      "tiny": "12px",
      "mono-tile": "20px"
    }
  },
  "semantic": {
    "--bg1": {
      "value": "#181222",
      "use": "Page background (top of gradient)"
    },
    "--bg2": {
      "value": "#211734",
      "use": "Card / surface background"
    },
    "--bg3": {
      "value": "#0f0a18",
      "use": "Deep background (footer, wells)"
    },
    "--surface": {
      "value": "rgba(255,255,255,.045)",
      "use": "Subtle raised fill"
    },
    "--surface2": {
      "value": "rgba(255,255,255,.075)",
      "use": "Stronger raised fill (inputs, chips)"
    },
    "--line": {
      "value": "rgba(232,178,58,.18)",
      "use": "Hairline borders & dividers"
    },
    "--text": {
      "value": "#f3ecdf",
      "use": "Primary text"
    },
    "--muted": {
      "value": "#b0a48e",
      "use": "Secondary / caption text"
    },
    "--accent": {
      "value": "#e8b23a",
      "use": "Primary brand accent (buttons, active)"
    },
    "--accent2": {
      "value": "#f0c668",
      "use": "Secondary accent (highlights)"
    },
    "--accent3": {
      "value": "#fff4d6",
      "use": "Tertiary / glow accent"
    },
    "--good": {
      "value": "#5fd1a0",
      "use": "Success / mastered"
    },
    "--bad": {
      "value": "#e2557a",
      "use": "Error / missed"
    },
    "--display": {
      "value": "'Fraunces','Georgia',serif",
      "use": "Display typeface"
    },
    "--body": {
      "value": "'Hanken Grotesk','Segoe UI',sans-serif",
      "use": "Body typeface"
    },
    "--mono": {
      "value": "'Space Mono',monospace",
      "use": "Mono typeface (spelling tiles)"
    },
    "--glow": {
      "value": "0 14px 50px rgba(0,0,0,.5)",
      "use": "Ambient shadow/glow"
    },
    "--chip": {
      "value": "rgba(232,178,58,.14)",
      "use": "Chip / pill tint"
    }
  },
  "themes": {
